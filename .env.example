# Vercel KV (Redis) — Vercel 대시보드에서 생성 시 자동으로 주입됨
# 로컬 개발 시 Vercel CLI로 `vercel env pull .env.development.local`로 가져오면 됨
# (없어도 앱은 메모리 폴백으로 작동 — 서버 재시작하면 초기화됨)

# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Anthropic API (scripts/import-directory.mjs 에서 사용)
# console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=

# Gmail API (콜드메일 발송 — /api/send-email)
# 발급: console.cloud.google.com → OAuth 2.0 클라이언트 ID → node scripts/gmail-auth.mjs
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=felix@madsq.net
